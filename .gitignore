# Allowlist: this folder also contains an unrelated project (src/, scripts/,
# pyproject.toml, .env, feeds.json) that must never be committed to this repo.
# Everything is ignored unless explicitly re-included below.
/*
!/.gitignore
!/README.md
!/DESIGN.md
!/mkdocs.yml
!/requirements-site.txt
!/.github/
!/docs/
!/tests/
!/requirements-test.txt

# Belt and braces (also excluded by /* above)
site/
test-artifacts/
.venv/
.env
__pycache__/
.DS_Store
